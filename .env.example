# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://agentflow:password@localhost:5432/agentflow
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agentflow
DB_USER=agentflow
DB_PASSWORD=password

# Mock mode (true = use mocks instead of real APIs)
USE_MOCK_INTEGRATIONS=true

# Salesforce (only needed if USE_MOCK_INTEGRATIONS=false)
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com

# Zendesk (only needed if USE_MOCK_INTEGRATIONS=false)
ZENDESK_SUBDOMAIN=your_subdomain

# Meetings (only needed if USE_MOCK_INTEGRATIONS=false)
MEETING_BASE_URL=https://your-meetings-provider.com
