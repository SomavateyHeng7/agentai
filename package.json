{
  "name": "agentflow",
  "version": "1.0.0",
  "bin": {
    "agentflow": "bin/agentflow"
  },
  "description": "Production-ready AI agent framework powered by Claude API",
  "author": "Tey Heng <teyyyyyheng@users.noreply.github.com>",
  "license": "MIT",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:ui": "npm --prefix ui/web run dev",
    "build": "tsc",
    "start": "node dist/index.js",
    "build:ui": "npm --prefix ui/web run build",
    "start:ui": "npm --prefix ui/web run start",
    "dev:dashboard": "npm --prefix ui/web/dashboard run dev",
    "build:dashboard": "npm --prefix ui/web/dashboard run build",
    "demo": "node scripts/demo.js",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "db:migrate": "node -e \"require('./dist/integrations/database').runMigrations()\"",
    "cli": "node dist/cli/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "express": "^4.18.2",
    "zod": "^3.22.4",
    "prom-client": "^15.1.0",
    "pg": "^8.11.3",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "axios": "^1.6.2",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/jest": "^29.5.11",
    "@types/inquirer": "^9.0.7",
    "@types/ws": "^8.5.12",
    "typescript": "5.3.3",
    "ts-node-dev": "^2.0.0",
    "ts-jest": "^29.1.1",
    "jest": "^29.7.0",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"]
  }
}
